# LinkedIn Automation — Environment Variables
# Copy this file to .env and fill in your API keys

# NewsAPI.org — https://newsapi.org/register
NEWSAPI_KEY=

# GNews.io fallback — https://gnews.io/
GNEWS_API_KEY=

# HuggingFace Inference API — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Unsplash API — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# LinkedIn API — https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Date when the LinkedIn token was created (YYYY-MM-DD format)
LINKEDIN_TOKEN_CREATED_AT=

# Email notifications (Gmail SMTP)
EMAIL_FROM=
GMAIL_APP_PASSWORD=
EMAIL_TO=
